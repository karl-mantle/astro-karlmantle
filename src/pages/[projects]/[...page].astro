---
import type { GetStaticPathsOptions, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { collectionsConfig } from "~/site.config";
import { getProjects } from "~/scripts/collections/projects";
import Base from "~/layouts/Base.astro";
import ProjectsListing from "~/layouts/ProjectsListing.astro";

type Props = {
  page: Page<CollectionEntry<"projects">>;
};

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const projects = await getProjects();
  return paginate(projects, {
    params: { projects: collectionsConfig.permalink_projects },
    pageSize: collectionsConfig.projects_per_page || 8,
  });
}

const { page } = Astro.props;
---

<Base
  type="collectionPage"
  title={page.data.length > 0 ? `All posts ~ Page ${page.currentPage}` : "All posts"}
  description={page.data.length > 0
    ? `Now displaying ${page.start + 1} to ${page.end + 1} posts out of ${page.total} posts.
`
    : "There are currently no posts to show."}
  page={page}
>
  <ProjectsListing
    title="Viewing all posts"
    description={page.data.length > 0
      ? `Now displaying ${page.start + 1} to ${page.end + 1} posts out of ${page.total} posts.
`
      : "There are currently no posts to show"}
    page={page}
  />
</Base>
