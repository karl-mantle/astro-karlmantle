---
import { siteConfig } from "~/site.config";
import Base from "~/layouts/Base.astro";
import TextBtn from "~/components/ui/buttons/TextBtn.astro";
import RecentPosts from "~/components/blog/RecentPosts.astro";
---

<Base
  type="webpage"
  title="404 Page not found"
  description="Oops! That page doesn't exist. It might've been moved, renamed, or never existed at all.
"
>
  <section class="mt-8 flex flex-col gap-4 sm:mt-16">
    <h1 class="text-2xl font-bold lowercase">404 - Page not found</h1>

    <p class="lowercase sm:mb-4">
      Oops! That page doesn't exist. It might've been moved, renamed, or never existed at all.
    </p>

    <TextBtn label="<< Return home" href={siteConfig.url} />
  </section>

  <section class="mt-8 flex flex-col gap-4 sm:mt-16">
    <h2 class="text-xl font-bold lowercase">Latest updates</h2>
    <RecentPosts max={3} />
  </section>
</Base>
