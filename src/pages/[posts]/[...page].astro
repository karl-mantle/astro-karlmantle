---
import type { GetStaticPathsOptions, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { collectionsConfig } from "~/site.config";
import { getPosts } from "~/scripts/collections/posts";
import Base from "~/layouts/Base.astro";
import Listing from "~/layouts/Listing.astro";

type Props = {
  page: Page<CollectionEntry<"posts">>;
};

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPosts();
  return paginate(posts, {
    params: { posts: collectionsConfig.permalink_posts },
    pageSize: collectionsConfig.posts_per_page || 9,
  });
}

const { page } = Astro.props;
---

<Base
  title=`All posts page ${page.currentPage}`
  description=`Now displaying ${page.start + 1} to ${page.end + 1} posts out of ${page.total} posts.
`
>
  <Listing
    title="Viewing all posts"
    description=`Now displaying ${page.start + 1} to ${page.end + 1} posts out of ${page.total} posts.
`
    page={page}
  />
</Base>
