---
import Base from "~/layouts/Base.astro";
import Form from "~/components/contact/Form.astro";
import TextBtn from "~/components/ui/buttons/TextBtn.astro";
---

<Base type="webpage" title="Contact" description="Contact page">
  <section class="mt-8 flex flex-col gap-4 lowercase sm:mt-16">
    <h1 class="text-2xl font-bold">Contact</h1>
    <p class="sm:mb-4">
      You can contact me either by emailing <TextBtn
        label="root@karlmantle.com"
        href="mailto:root@karlmantle.com"
      /> or using the form below.
    </p>
    <Form />
  </section>
</Base>
