---
import Head from "~/layouts/Head.astro";
import Header from "~/components/common/Header.astro";
import { siteConfig } from "~/site.config";

type Props = {
  description?: string;
  entry?: any;
  title?: string;
};

const { description, entry, title } = Astro.props;
---

<!doctype html>
<html lang={siteConfig.language}>
  <Head description={description} entry={entry} title={title} />

  <body class="relative min-h-screen bg-white font-mono text-black dark:bg-black dark:text-white">
    <Header />
    <main id="main" class="mx-auto max-w-xl px-4">
      <slot />
    </main>
  </body>
</html>
