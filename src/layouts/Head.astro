---
import { getImage } from "astro:assets";
import opengraphImageSrc from "public/opengraph.webp";

interface Props {
  description?: string;
  entry?: any;
  title?: string;
}

const { description, entry, title }: Props = Astro.props;

const opengraphImage = entry?.data.image?.src ?? opengraphImageSrc;

const metadata = {
  canonical: new URL(Astro.url.pathname, Astro.site),
  description: description ?? entry?.data.description,
  image: await getImage({ src: opengraphImage, width: 1200, height: 630 }),
  title: `${title ?? entry?.data.title} ~ karlmantle.com`,
};
---

<head>
  <meta charset="utf-8" />
  <title>{metadata.title}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="title" content={metadata.title} />
  <meta name="description" content={metadata.description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="canonical" href={metadata.canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={metadata.title} />
  <meta property="og:description" content={metadata.description} />
  <meta property="og:image" content={metadata.image.src} />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={metadata.title} />
  <meta property="twitter:description" content={metadata.description} />
  <meta property="twitter:image" content={metadata.image.src} />

  <slot />
</head>
