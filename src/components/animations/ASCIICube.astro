<div class="mt-4 relative h-80 flex justify-center overflow-hidden">
  <pre
    id="ascii-cube"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 whitespace-pre font-mono text-[11px] leading-none pointer-events-none text-pink-400 letter-spacing-[2px]"
    aria-hidden="true">
  </pre>
</div>

<script type="module">
  import { ASCIICube } from "/src/scripts/animations/asciiCube";

  function initASCIICube() {
    const el = document.getElementById("ascii-cube");

    if (el) {
      const cube = new ASCIICube(el);
      cube.animate();
    }
  }

  document.addEventListener("DOMContentLoaded", initASCIICube);
</script>
