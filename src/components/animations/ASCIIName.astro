      ‚ĖĎ          ‚ĖĎ  ‚ĖĎ   ‚ĖĎ         ‚ĖĎ  ‚ĖĎ         ‚ĖĎ`;
---

<section
  id="hero-ascii-wrapper"
  class:list={[
    "relative flex flex-col items-center overflow-hidden before:absolute before:opacity-0 before:mix-blend-screen before:content-[''] after:absolute after:translate-x-[-50%] after:translate-y-[-50%] after:opacity-0 after:blur-sm after:content-['']",
    className,
  ]}
>
  <pre
    id="hero-ascii"
    class="z-1 text-[11px] sm:text-lg"
    data-ascii-text={ascii}
    set:html={ascii}
  />
  <pre
    id="hero-ascii-glitch"
    class="ascii-glitch absolute inset-0 z-2 text-[11px] text-pink-400 opacity-50 sm:text-lg"
    aria-hidden="true">
  </pre>
  <h1 class="sr-only">{title}</h1>
</section>

<script>
  import { initHomeAsciiGlitch } from "~/scripts/animations/asciiName";

  document.addEventListener("astro:page-load", () => {
    setTimeout(() => {
      initHomeAsciiGlitch();
    }, 200);
  });
</script>

<style>
  .hero-ascii-wrapper::before {
    top: var(--ascii-scan-top, 0);
    left: var(--ascii-scan-left, 0);
    width: var(--ascii-scan-width, 0);
    height: var(--ascii-scan-height, 0);
  }

  .hero-ascii-wrapper::after {
    top: var(--ascii-bloom-y, 50%);
    left: var(--ascii-bloom-x, 50%);
    width: calc(var(--text-cell) * 7);
    height: calc(var(--text-size) * 2);
  }

  .hero-ascii-wrapper.is-glitching::before {
    opacity: var(--ascii-scan-opacity, 0.6);
  }

  .hero-ascii-wrapper.is-glitching::after {
    opacity: var(--ascii-bloom-opacity, 0.03);
  }

  .ascii-glitch {
    text-shadow:
      var(--ascii-glitch-shadow-a, 2px) 0 var(--fg),
      var(--ascii-glitch-shadow-b, -2px) 0 var(--link-hover);
    transform: translate(var(--ascii-glitch-shift-x, 0), var(--ascii-glitch-shift-y, 0));
    clip-path: inset(
      var(--ascii-glitch-clip-top, 0) var(--ascii-glitch-clip-right, 0)
        var(--ascii-glitch-clip-bottom, 0) var(--ascii-glitch-clip-left, 0)
    );
  }

  .hero-ascii-wrapper.is-glitching .ascii-glitch {
    opacity: var(--ascii-glitch-opacity, 0.72);
  }
</style>
