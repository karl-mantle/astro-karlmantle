---
import { Icon } from "astro-icon/components";
import ScrollToTop from "~/components/ui/a11y/ScrollToTop.astro";
import ThemeBtn from "~/components/ui/buttons/ThemeBtn.astro";

const socialLinks = [
  {
    href: "https://www.linkedin.com/in/karlmantle/",
    icon: "simple-icons:linkedin",
    label: "Visit my LinkedIn",
  },
  {
    href: "https://github.com/karl-mantle/",
    icon: "simple-icons:github",
    label: "Visit my GitHub",
  },
  {
    href: "/rss.xml",
    icon: "simple-icons:rss",
    label: "Subscribe to RSS feed",
  },
];
---

<footer
  id="site-footer"
  class="mx-auto mt-8 flex max-w-xl flex-col gap-4 border-t p-4 md:mt-16 md:flex-row md:justify-between md:gap-8"
>
  <ul id="footer-toolbar" class="flex md:flex-row">
    <li>
      <ScrollToTop />
    </li>
    <li>
      <ThemeBtn />
    </li>
  </ul>
  <ul class="flex gap-4">
    {
      socialLinks.map((item) => (
        <li class="mb-2">
          <a
            class="flex w-fit flex-row items-center gap-2 text-neutral-900 lowercase hover:bg-pink-200 hover:text-neutral-900 dark:text-neutral-100"
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={item.label}
          >
            <Icon class="self-center" name={item.icon} height={18} width={18} />
          </a>
        </li>
      ))
    }
  </ul>
</footer>
