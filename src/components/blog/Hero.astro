---
import type { ImageMetadata } from "astro";
import type { HTMLAttributes } from "astro/types";
import { Picture } from "astro:assets";
import { collectionsConfig, imagesConfig, siteConfig } from "src/site.config";
import slugify from "slugify";
import Date from "~/components/ui/Date.astro";
import TextBtn from "~/components/ui/buttons/TextBtn.astro";

type Props = HTMLAttributes<"header"> & {
  category: string;
  date: Date;
  description: string;
  heading: string;
  image?: {
    alt: string | null;
    src: ImageMetadata;
  };
};

const { category, date, heading, image } = Astro.props;
---

<header class="flex flex-col gap-4">
  <div class="relative aspect-video overflow-hidden">
    {
      image && (
        <Picture
          alt={image.alt ?? ""}
          class="absolute inset-0 h-full w-full object-cover"
          format="webp"
          loading="eager"
          sizes={imagesConfig.third.sizes}
          src={image.src}
          widths={imagesConfig.third.widths}
        />
      )
    }

    <div class="absolute inset-0 z-2 bg-linear-to-tr from-black via-black/75 to-black/25"></div>

    <div class="absolute inset-0 z-3 flex items-end p-4">
      <h1 class="text-2xl text-white lowercase sm:text-3xl">
        {heading}
      </h1>
    </div>
  </div>

  <div class="flex gap-2 text-sm">
    <Date date={date} />
    <span aria-hidden="true">|</span>
    <TextBtn
      href={`${siteConfig.url}${collectionsConfig.permalink_posts_category}${slugify(category, { lower: true })}`}
      label={category}
    />
  </div>
</header>
